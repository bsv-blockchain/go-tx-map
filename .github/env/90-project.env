# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-tx-map
# Load Order: 90 (loaded late, overrides all default and tool-specific configuration)
#
# This file contains configuration values that are specific to this project and
# override defaults from earlier env files (00-core, 10-*, 20-*).
#
# Common overrides include:
# - Coverage provider and exclusion paths
# - Codecov token requirements
# - Project-specific feature flags
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X CONFIGURATION
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION OVERRIDES
# ================================================================================================

# Coverage Provider Selection (override: use codecov instead of internal)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusion Paths
# Matches codecov.yml ignore paths plus project-specific exclusions
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,examples/,example/,plans/,docs/,.github/,.mage-cache/,.vscode/,bin/,mocks/,testing/
